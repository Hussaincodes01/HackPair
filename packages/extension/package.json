{
  "name": "hackpair",
  "displayName": "HackPair",
  "description": "Real-time code collaboration. Connect to a HackPair server and code with your team.",
  "version": "0.2.5",
  "publisher": "Hussaincodes01",
  "icon": "icon.png",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Hussaincodes01/hackpair" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["collaboration", "real-time", "hackathon", "live-share"],
  "activationEvents": [
    "onView:hackpair.panel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{ "id": "hacksync", "title": "HackPair", "icon": "$(sync)" }]
    },
    "views": {
      "hacksync": [{
        "type": "webview",
        "id": "hackpair.panel",
        "name": "HackPair"
      }]
    }
  },
  "scripts": {
    "build": "node build.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "cloudflared": "^0.7.1",
    "socket.io-client": "^4.7.0"
  }
}
