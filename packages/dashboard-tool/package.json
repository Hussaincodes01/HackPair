{
  "name": "hackpair-server",
  "version": "0.3.2",
  "description": "Standalone HackPair server with web dashboard. Manage rooms, see members, monitor activity.",
  "main": "./dist/index.js",
  "bin": {
    "hackpair-server": "./dist/index.js"
  },
  "license": "MIT",
  "keywords": [
    "hackpair",
    "collaboration",
    "real-time",
    "dashboard"
  ],
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js && node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "cloudflared": "^0.7.1",
    "fastify": "^4.27.0",
    "socket.io": "^4.7.0",
    "sql.js": "^1.10.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "@types/node": "^20.12.0"
  },
  "engines": {
    "node": ">=18"
  }
}
